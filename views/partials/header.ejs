<!DOCTYPE html>
<html lang="uz">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TATU Onlayn Kutubxona</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.0.0/css/flag-icons.min.css" />
    <script>
        (function () {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
</head>

<body>
    <% if (locals.user && locals.facultyFilter) { %>
        <%- include('chatbot') %>
            <% } %>
                <header>
                    <div class="container">
                        <nav>
                            <a href="/" class="logo">
                                <i class="fas fa-university"></i> TATU Digital Library
                            </a>
                            <div class="nav-links">
                                <div class="lang-switcher">
                                    <a href="/set-lang/uz"
                                        class="<%= (locals.currentLang === 'uz') ? 'active' : '' %>"><span
                                            class="fi fi-uz"></span> UZ</a>
                                    <a href="/set-lang/ru"
                                        class="<%= (locals.currentLang === 'ru') ? 'active' : '' %>"><span
                                            class="fi fi-ru"></span> RU</a>
                                    <a href="/set-lang/en"
                                        class="<%= (locals.currentLang === 'en') ? 'active' : '' %>"><span
                                            class="fi fi-gb"></span> EN</a>
                                </div>
                                <button id="theme-toggle" class="theme-btn-premium"
                                    title="<%= locals.t ? locals.t('design') : 'Dizayn' %>">
                                    <i class="fas fa-moon"></i>
                                </button>
                                <% if (!locals.isLandingPage) { %>
                                    <% if (locals.user) { %>
                                        <% if (locals.user.role==='admin' ) { %>
                                            <a href="/admin">
                                                <%= locals.t ? locals.t('admin_panel') : 'Admin Panel' %>
                                            </a>
                                            <% } %>

                                                <a href="/library/my-books" style="margin-left: 10px;">
                                                    <i class="fas fa-bookmark"></i>
                                                    <%= locals.t ? locals.t('my_books') : 'Mening kitoblarim' %>
                                                </a>

                                                <a href="/logout" style="margin-left: 10px;">
                                                    <i class="fas fa-sign-out-alt"></i>
                                                    <%= locals.t ? locals.t('logout') : 'Chiqish' %>
                                                </a>
                                                <% } else { %>
                                                    <a href="/login">
                                                        <%= locals.t ? locals.t('login') : 'Kirish' %>
                                                    </a>
                                                    <a href="/register">
                                                        <%= locals.t ? locals.t('register') : 'Ro\' yxatdan o\'tish' %>
                                                    </a>
                                                    <% } %>
                                                        <% } %>
                            </div>
                        </nav>
                    </div>
                </header>
                <main>
                    <script>
                        const themeToggle = document.getElementById('theme-toggle');
                        if (themeToggle) {
                            const html = document.documentElement;
                            const icon = themeToggle.querySelector('i');

                            function updateIcon(theme) {
                                if (theme === 'dark') {
                                    icon.classList.remove('fa-moon');
                                    icon.classList.add('fa-sun');
                                } else {
                                    icon.classList.remove('fa-sun');
                                    icon.classList.add('fa-moon');
                                }
                            }

                            updateIcon(html.getAttribute('data-theme'));

                            themeToggle.addEventListener('click', () => {
                                const currentTheme = html.getAttribute('data-theme');
                                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

                                html.setAttribute('data-theme', newTheme);
                                localStorage.setItem('theme', newTheme);
                                updateIcon(newTheme);
                            });
                        }
                    </script>