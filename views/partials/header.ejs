<!DOCTYPE html>
<html lang="uz">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TATU Onlayn Kutubxona</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.0.0/css/flag-icons.min.css" />
    <script>
        (function () {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
</head>

<body>
    <% if (locals.user && locals.facultyFilter) { %>
        <%- include('chatbot') %>
            <% } %>
                <header>
                    <div class="container">
                        <nav>
                            <a href="/" class="logo">
                                <i class="fas fa-university"></i> TATU Digital Library
                            </a>
                            <div class="nav-links">
                                <div class="lang-switcher">
                                    <a href="/set-lang/uz"
                                        class="<%= (locals.currentLang === 'uz') ? 'active' : '' %>"><span
                                            class="fi fi-uz"></span> UZ</a>
                                    <a href="/set-lang/ru"
                                        class="<%= (locals.currentLang === 'ru') ? 'active' : '' %>"><span
                                            class="fi fi-ru"></span> RU</a>
                                    <a href="/set-lang/en"
                                        class="<%= (locals.currentLang === 'en') ? 'active' : '' %>"><span
                                            class="fi fi-gb"></span> EN</a>
                                </div>

                                <div class="notifications-wrapper">
                                    <button class="notification-bell" id="notif-btn">
                                        <i class="fas fa-bell"></i>
                                        <span class="notification-badge" id="notif-badge">0</span>
                                    </button>
                                    <div class="notification-dropdown" id="notif-dropdown">
                                        <div class="notification-header">
                                            <span>
                                                <%= locals.t ? locals.t('notifications') : 'Bildirishnomalar' %>
                                            </span>
                                        </div>
                                        <div class="notification-list" id="notif-list">
                                            <div class="no-notifications">Yuklanmoqda...</div>
                                        </div>
                                    </div>
                                </div>

                                <button id="theme-toggle" class="theme-btn-premium"
                                    title="<%= locals.t ? locals.t('design') : 'Dizayn' %>">
                                    <i class="fas fa-moon"></i>
                                </button>
                                <% if (!locals.isLandingPage) { %>
                                    <% if (locals.user) { %>
                                        <% if (locals.user.role==='admin' ) { %>
                                            <a href="/admin">
                                                <%= locals.t ? locals.t('admin_panel') : 'Admin Panel' %>
                                            </a>
                                            <% } %>

                                                <a href="/library/my-books" style="margin-left: 10px;">
                                                    <i class="fas fa-bookmark"></i>
                                                    <%= locals.t ? locals.t('my_books') : 'Mening kitoblarim' %>
                                                </a>

                                                <a href="/logout" style="margin-left: 10px;">
                                                    <i class="fas fa-sign-out-alt"></i>
                                                    <%= locals.t ? locals.t('logout') : 'Chiqish' %>
                                                </a>
                                                <% } else { %>
                                                    <a href="/login">
                                                        <%= locals.t ? locals.t('login') : 'Kirish' %>
                                                    </a>
                                                    <a href="/register">
                                                        <%= locals.t ? locals.t('register') : 'Ro\' yxatdan o\'tish' %>
                                                    </a>
                                                    <% } %>
                                                        <% } %>
                            </div>
                        </nav>
                    </div>
                </header>
                <main>
                    <script>
                        const themeToggle = document.getElementById('theme-toggle');
                        if (themeToggle) {
                            const html = document.documentElement;
                            const icon = themeToggle.querySelector('i');

                            function updateIcon(theme) {
                                if (theme === 'dark') {
                                    icon.classList.remove('fa-moon');
                                    icon.classList.add('fa-sun');
                                } else {
                                    icon.classList.remove('fa-sun');
                                    icon.classList.add('fa-moon');
                                }
                            }

                            updateIcon(html.getAttribute('data-theme'));

                            themeToggle.addEventListener('click', () => {
                                const currentTheme = html.getAttribute('data-theme');
                                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

                                html.setAttribute('data-theme', newTheme);
                                localStorage.setItem('theme', newTheme);
                                updateIcon(newTheme);
                            });
                        }

                        // Notifications Script
                        const notifBtn = document.getElementById('notif-btn');
                        const notifDropdown = document.getElementById('notif-dropdown');
                        const notifList = document.getElementById('notif-list');
                        const notifBadge = document.getElementById('notif-badge');
                        const currentLang = '<%= locals.currentLang %>';

                        async function fetchNotifications() {
                            try {
                                const res = await fetch('/notifications');
                                const data = await res.json();
                                renderNotifications(data);
                            } catch (e) { console.error(e); }
                        }

                        function renderNotifications(notifs) {
                            if (!notifs || notifs.length === 0) {
                                notifList.innerHTML = '<div class="no-notifications">Yangi xabarlar yo\'q</div>';
                                notifBadge.style.display = 'none';
                                return;
                            }

                            const unreadCount = notifs.filter(n => !n.is_read).length;
                            if (unreadCount > 0) {
                                notifBadge.textContent = unreadCount;
                                notifBadge.style.display = 'flex';
                            } else {
                                notifBadge.style.display = 'none';
                            }

                            notifList.innerHTML = notifs.map(n => {
                                const msg = n['message_' + currentLang] || n.message_uz;
                                return `
                                    <a href="${n.link}" class="notification-item ${n.is_read ? '' : 'unread'}">
                                        <p>${msg}</p>
                                        <span class="notification-time">${new Date(n.created_at).toLocaleString()}</span>
                                    </a>
                                `;
                            }).join('');
                        }

                        if (notifBtn) {
                            notifBtn.addEventListener('click', (e) => {
                                e.stopPropagation();
                                notifDropdown.classList.toggle('active');
                                if (notifDropdown.classList.contains('active')) {
                                    // Mark as read locally or server-side if needed
                                }
                            });
                        }

                        document.addEventListener('click', (e) => {
                            if (notifDropdown && !notifDropdown.contains(e.target) && e.target !== notifBtn) {
                                notifDropdown.classList.remove('active');
                            }
                        });

                        // Initial fetch
                        fetchNotifications();
                        // Poll every 60 seconds
                        setInterval(fetchNotifications, 60000);
                    </script>