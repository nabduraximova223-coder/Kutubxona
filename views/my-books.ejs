<%- include('partials/header') %>

    <div class="container">
        <div class="view-header" style="margin-bottom: 2rem;">
            <h2 style="display: flex; align-items: center; gap: 15px;">
                <i class="fas fa-bookmark" style="color: var(--primary-color);"></i>
                <%= locals.t ? locals.t('my_books') : 'Mening kitoblarim' %>
            </h2>
            <p style="color: var(--text-muted); margin-top: 5px;">
                <%= locals.t ? locals.t('my_books_subtitle') : 'Siz yuklab olgan barcha elektron resurslar' %>
            </p>
        </div>

        <div class="book-grid">
            <% if (locals.books && books.length> 0) { %>
                <% books.forEach(book=> { %>
                    <div class="book-card">
                        <div class="book-info">
                            <h3 class="book-title"
                                style="display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 0.5rem;">
                                <span style="flex: 1;">
                                    <%= book.title %>
                                </span>
                                <div class="book-rating" data-book-id="<%= book.id %>"
                                    data-original-rating="<%= (book.rating_count > 0 ? (book.rating_sum / book.rating_count) : 0).toFixed(1) %>"
                                    style="display: flex; gap: 3px; cursor: pointer; white-space: nowrap;">
                                    <% const count=book.rating_count || 0; const sum=book.rating_sum || 0; const
                                        avg=count> 0 ? (sum / count) : 0;
                                        for(let i=1; i<=5; i++) { const isFilled=i <=Math.round(avg); %>
                                            <i class="<%= isFilled ? 'fas' : 'far' %> fa-star" data-rating="<%= i %>"
                                                style="color: #FFD700; font-size: 1.1rem;"></i>
                                            <% } %>
                                                <span
                                                    style="font-size: 0.85rem; color: var(--text-muted); margin-left: 5px; align-self: center;">(
                                                    <%= avg.toFixed(1) %>)</span>
                                </div>
                            </h3>
                            <p class="book-author"><i class="fas fa-user-edit"></i>
                                <%= book.author %>
                            </p>
                            <p class="book-desc">
                                <%= book.description %>
                            </p>

                            <div
                                style="margin-top: 10px; font-size: 0.85rem; color: var(--text-muted); display: flex; align-items: center; gap: 5px;">
                                <i class="far fa-clock"></i>
                                <%= new Date(book.downloaded_at).toLocaleDateString() %> da yuklangan
                            </div>

                            <div style="margin-top: 1.5rem; display: flex; gap: 10px;">
                                <a href="/download/<%= book.id %>" class="btn btn-primary"
                                    style="flex: 1; text-align: center; padding: 0.5rem 1rem;">
                                    <i class="fas fa-file-pdf" style="margin-right: 5px;"></i>
                                    <%= locals.t ? locals.t('download') : 'Yuklab olish' %>
                                </a>
                                <a href="/read/<%= book.id %>" target="_blank" class="btn btn-primary"
                                    style="flex: 1; text-align: center; padding: 0.5rem 1rem; background-color: var(--secondary-color, #4CAF50); border: none;">
                                    <i class="fas fa-book-open" style="margin-right: 5px;"></i>
                                    <%= locals.t ? locals.t('open_book') : 'O\' qish' %>
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="no-results"
                                style="grid-column: 1/-1; text-align: center; padding: 4rem; background: #fff; border-radius: 16px; border: 1px dashed var(--border-color);">
                                <i class="fas fa-cloud-download-alt"
                                    style="font-size: 4rem; color: var(--border-color); margin-bottom: 1.5rem; display: block;"></i>
                                <h3>Hozircha yuklab olingan kitoblar yo'q</h3>
                                <p style="color: var(--text-muted); margin: 15px 0;">Siz yuklab olgan kitoblar shu yerda
                                    paydo bo'ladi.</p>
                                <a href="/library" class="btn btn-primary" style="margin-top: 1rem;">
                                    <%= locals.t ? locals.t('books') : 'Kitoblarni ko\' rish' %>
                                </a>
                            </div>
                            <% } %>
        </div>
    </div>

    <script>
        // Star rating client-side logic (reused from library.ejs)
        document.querySelectorAll('.book-rating').forEach(container => {
            const stars = container.querySelectorAll('i.fa-star');
            const originalRating = Math.round(parseFloat(container.getAttribute('data-original-rating') || 0));

            stars.forEach(star => {
                star.addEventListener('mouseenter', function () {
                    const rating = parseInt(this.getAttribute('data-rating'));
                    stars.forEach(s => {
                        const sRating = parseInt(s.getAttribute('data-rating'));
                        if (sRating <= rating) {
                            s.classList.remove('far');
                            s.classList.add('fas');
                        } else {
                            s.classList.add('far');
                            s.classList.remove('fas');
                        }
                    });
                });
            });

            container.addEventListener('mouseleave', function () {
                stars.forEach(s => {
                    const sRating = parseInt(s.getAttribute('data-rating'));
                    if (sRating <= originalRating) {
                        s.classList.remove('far');
                        s.classList.add('fas');
                    } else {
                        s.classList.add('far');
                        s.classList.remove('fas');
                    }
                });
            });

            stars.forEach(star => {
                star.addEventListener('click', function () {
                    const rating = parseInt(this.getAttribute('data-rating'));
                    const bookId = container.getAttribute('data-book-id');

                    fetch('/rate/' + bookId, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ rating: rating })
                    })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                window.location.reload();
                            } else {
                                alert("Baholashda xatolik yuz berdi");
                            }
                        })
                        .catch(err => {
                            console.error(err);
                            alert("Server xatosi yuz berdi");
                        });
                });
            });
        });
    </script>

    <%- include('partials/footer') %>