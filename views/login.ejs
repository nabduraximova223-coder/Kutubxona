<%- include('partials/header') %>

    <div class="form-container">
        <h2 style="text-align: center; margin-bottom: 1rem;">
            <%= locals.t ? locals.t('login_title') : 'Tizimga kirish' %>
        </h2>

        <% if (locals.error) { %>
            <div style="background: #ffebee; color: #c62828; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
                <%= error %>
            </div>
            <% } %>

                <form action="/login" method="POST">
                    <div class="form-group">
                        <label>
                            <%= locals.t ? locals.t('username') : 'Foydalanuvchi nomi' %>
                        </label>
                        <input type="text" name="username" required>
                    </div>
                    <div class="form-group">
                        <label>
                            <%= locals.t ? locals.t('password') : 'Parol' %>
                        </label>
                        <div style="position: relative;">
                            <input type="password" name="password" required style="padding-right: 40px;">
                            <i class="fas fa-eye-slash"
                                style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #7f8c8d;"
                                onclick="togglePassword(this)"></i>
                        </div>
                    </div>
                    <button type="submit" class="btn" style="width: 100%;">
                        <%= locals.t ? locals.t('login') : 'Kirish' %>
                    </button>
                </form>
                <p style="text-align: center; margin-top: 1rem;">
                    <%= locals.t ? locals.t('no_account') : 'Hisobingiz yo\' qmi?' %> <a href="/register">
                            <%= locals.t ? locals.t('register') : 'Ro\' yxatdan o\'tish' %>
                        </a>
                </p>
    </div>

    <script>
        function togglePassword(icon) {
            const input = icon.previousElementSibling;
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            } else {
                input.type = "password";
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            }
        }
    </script>
    <%- include('partials/footer') %>