<%- include('partials/header') %>

    <div class="form-container" style="max-width: 800px;">
        <h2 style="text-align: center; margin-bottom: 2rem;">
            <%= locals.t ? locals.t('register_title') : 'Ro\' yxatdan o\'tish' %>
        </h2>

        <% if (locals.error) { %>
            <div style="background: #ffebee; color: #c62828; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
                <%= error %>
            </div>
            <% } %>

                <form action="/register" method="POST" onsubmit="return validateForm()">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;" class="register-grid">
                        <!-- Left Column -->
                        <div class="registration-col">
                            <div class="form-group">
                                <label>Ism</label>
                                <input type="text" name="firstname" id="firstname" placeholder="Ismingiz" required>
                            </div>
                            <div class="form-group">
                                <label>Familiya</label>
                                <input type="text" name="lastname" id="lastname" placeholder="Familiyangiz" required>
                            </div>
                            <div class="form-group">
                                <label>
                                    <%= locals.t ? locals.t('email') : 'Email manzil' %>
                                </label>
                                <input type="email" name="email" id="email" placeholder="example@gmail.com" required>
                            </div>
                            <div class="form-group">
                                <label>Telefon raqam</label>
                                <input type="tel" name="phone" id="phone" placeholder="+998 90 123 45 67" required>
                            </div>
                        </div>

                        <!-- Right Column -->
                        <div class="registration-col">
                            <div class="form-group">
                                <label>Login (Username)</label>
                                <input type="text" name="username" id="username" placeholder="Login tanlang" required
                                    autocomplete="username">
                            </div>
                            <div class="form-group">
                                <label>
                                    <%= locals.t ? locals.t('password') : 'Parol' %>
                                </label>
                                <div style="position: relative;">
                                    <input type="password" name="password" id="password" required
                                        placeholder="Katta, kichik harf va son" style="padding-right: 40px;"
                                        oninput="checkStrength(this.value)" autocomplete="new-password">
                                    <i class="fas fa-eye-slash"
                                        style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #7f8c8d;"
                                        onclick="togglePassword(this)"></i>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Parolni tasdiqlash</label>
                                <input type="password" name="confirm_password" id="confirm_password" required
                                    placeholder="Parolni qayta kiriting" autocomplete="new-password">
                            </div>

                            <div class="form-group">
                                <label>
                                    <%= locals.t ? locals.t('math_example') : 'Matematik misol' %>: <strong>
                                            <%= locals.challenge %> = ?
                                        </strong>
                                </label>
                                <input type="text" name="challenge_answer" required
                                    placeholder="<%= locals.t ? locals.t('enter_answer') : 'Javobni kiriting' %>">
                            </div>
                        </div>
                    </div>

                    <div id="strength-box"
                        style="margin:8px 0 15px 0; font-size:13px; display:none; background: #f8f9fa; padding: 10px; border-radius: 8px; border: 1px solid #ddd;">
                        <div id="strength-bar"
                            style="height:5px; border-radius:3px; width:0%; transition:width 0.3s, background 0.3s; margin-bottom: 8px;">
                        </div>
                        <ul id="requirements" style="margin:0; padding:0; list-style: none;">
                            <li id="req-len" style="margin-bottom: 2px;"><i class="fas fa-circle"
                                    style="font-size: 8px; margin-right: 5px;"></i> Kamida 8 ta belgi</li>
                            <li id="req-upper" style="margin-bottom: 2px;"><i class="fas fa-circle"
                                    style="font-size: 8px; margin-right: 5px;"></i> Kamida 1 ta KATTA harf</li>
                            <li id="req-lower" style="margin-bottom: 2px;"><i class="fas fa-circle"
                                    style="font-size: 8px; margin-right: 5px;"></i> Kamida 1 ta kichik harf</li>
                            <li id="req-num" style="margin-bottom: 2px;"><i class="fas fa-circle"
                                    style="font-size: 8px; margin-right: 5px;"></i> Kamida 1 ta raqam</li>
                        </ul>
                    </div>

                    <div id="form-error"
                        style="display:none; background:#ffebee; color:#c62828; padding:10px; border-radius:4px; margin-bottom:15px; border-left: 4px solid #c62828;">
                    </div>

                    <button type="submit" class="btn" style="width: 100%; text-transform: uppercase;">
                        <%= locals.t ? locals.t('register') : 'Ro\' yxatdan o\'tish' %>
                    </button>
                </form>
                <p style="text-align: center; margin-top: 1.5rem;">
                    <%= locals.t ? locals.t('have_account') : 'Hisobingiz bormi?' %> <a href="/login">
                            <%= locals.t ? locals.t('login') : 'Kirish' %>
                        </a>
                </p>
    </div>

    <script>
        function togglePassword(icon) {
            const input = icon.previousElementSibling;
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            } else {
                input.type = "password";
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            }
        }

        function checkStrength(val) {
            const box = document.getElementById('strength-box');
            box.style.display = val.length > 0 ? 'block' : 'none';

            const hasLen = val.length >= 8;
            const hasUpper = /[A-Z]/.test(val);
            const hasLower = /[a-z]/.test(val);
            const hasNum = /[0-9]/.test(val);

            mark('req-len', hasLen);
            mark('req-upper', hasUpper);
            mark('req-lower', hasLower);
            mark('req-num', hasNum);

            const score = [hasLen, hasUpper, hasLower, hasNum].filter(Boolean).length;
            const bar = document.getElementById('strength-bar');
            const colors = ['#e53935', '#fb8c00', '#fdd835', '#43a047'];
            bar.style.width = (score * 25) + '%';
            bar.style.background = colors[score - 1] || '#e0e0e0';
        }

        function mark(id, ok) {
            const el = document.getElementById(id);
            el.style.color = ok ? '#27ae60' : '#c0392b';
            el.style.fontWeight = ok ? 'bold' : 'normal';
        }

        function validateForm() {
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirm_password').value;
            const errDiv = document.getElementById('form-error');
            const errors = [];

            if (password !== confirmPassword) {
                errors.push("Parollar bir-biriga mos kelmadi.");
            }
            if (password.length < 8) errors.push("Parol kamida 8 ta belgidan iborat bo'lishi kerak.");
            if (!/[A-Z]/.test(password)) errors.push("Parolda kamida 1 ta KATTA harf bo'lishi shart.");
            if (!/[a-z]/.test(password)) errors.push("Parolda kamida 1 ta kichik harf bo'lishi shart.");
            if (!/[0-9]/.test(password)) errors.push("Parolda kamida 1 ta raqam bo'lishi shart.");

            if (errors.length > 0) {
                errDiv.style.display = 'block';
                errDiv.innerHTML = errors.join('<br>');
                window.scrollTo({ top: 0, behavior: 'smooth' });
                return false;
            }
            errDiv.style.display = 'none';
            return true;
        }
    </script>
    <%- include('partials/footer') %>