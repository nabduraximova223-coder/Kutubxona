<%- include('partials/header') %>

    <h2 style="margin-bottom: 1rem;">Admin Panel</h2>

    <div class="dashboard-stats"
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 2rem;">
        <div class="stat-card"
            style="background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); text-align: center; border-left: 5px solid var(--primary-color);">
            <i class="fas fa-book" style="font-size: 2rem; color: var(--primary-color); margin-bottom: 10px;"></i>
            <h4 style="color: var(--text-muted);">Jami kitoblar</h4>
            <p style="font-size: 2rem; font-weight: 800; color: var(--primary-color); margin: 0;">
                <%= books.length %>
            </p>
        </div>
        <div class="stat-card"
            style="background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); text-align: center; border-left: 5px solid var(--success-color);">
            <i class="fas fa-users" style="font-size: 2rem; color: var(--success-color); margin-bottom: 10px;"></i>
            <h4 style="color: var(--text-muted);">Ro'yxatdan o'tganlar</h4>
            <p style="font-size: 2rem; font-weight: 800; color: var(--success-color); margin: 0;">
                <%= userCount %>
            </p>
        </div>
    </div>

    <div class="form-container" style="max-width: 800px; margin: 0 auto 2rem;">
        <h3>Yangi kitob qo'shish</h3>
        <form action="/admin/add" method="POST" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group">
                    <label>Kitob nomi</label>
                    <input type="text" name="title" required>
                </div>
                <div class="form-group">
                    <label>Muallif</label>
                    <input type="text" name="author" required>
                </div>
                <div class="form-group">
                    <label>Fan / Soha</label>
                    <input type="text" name="subject" required>
                </div>
                <div class="form-group">
                    <label>Fakultet</label>
                    <select name="faculty" required>
                        <option value="all">Barcha fakultetlar (Umumiy)</option>
                        <option value="ki">Kompyuter injiniringi</option>
                        <option value="di">Dasturiy injiniring</option>
                        <option value="ax">Axborot xavfsizligi</option>
                        <option value="tt">Telekommunikatsiya texnologiyalari</option>
                        <option value="tv">Televizion texnologiyalar</option>
                        <option value="im">Iqtisodiyot va menejment</option>
                        <option value="kt">Kasb ta'limi</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Kurs</label>
                    <select name="course" required>
                        <option value="1">1-kurs</option>
                        <option value="2">2-kurs</option>
                        <option value="3">3-kurs</option>
                        <option value="4">4-kurs</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>PDF Fayl</label>
                    <input type="file" name="bookFile" accept="application/pdf" required>
                </div>
            </div>
            <div class="form-group">
                <label>Tavsif</label>
                <textarea name="description" rows="3"></textarea>
            </div>
            <button type="submit" class="btn">Qo'shish</button>
        </form>
    </div>

    <div style="margin-bottom: 3rem;">
        <h3>Foydalanuvchilar ro'yxati</h3>
        <div style="background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Login</th>
                        <th>Rol</th>
                        <th>Sana</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u=> { %>
                        <tr style="<%= u.id === user.id ? 'background: #f0f7ff;' : '' %>">
                            <td>
                                <%= u.id %>
                            </td>
                            <td><strong>
                                    <%= u.login %>
                                </strong></td>
                            <td>
                                <span
                                    style="padding: 3px 8px; border-radius: 4px; font-size: 0.8rem; background: <%= u.role === 'admin' ? '#fee2e2; color: #991b1b;' : '#e0f2fe; color: #075985;' %>">
                                    <%= u.role.toUpperCase() %>
                                </span>
                            </td>
                            <td>
                                <%= new Date(u.created_at).toLocaleDateString() %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <h3>Kitoblar ro'yxati</h3>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Nomi</th>
                <th>Muallif</th>
                <th>Fan</th>
                <th>Fakultet</th>
                <th>Kurs</th>
                <th>Amallar</th>
            </tr>
        </thead>
        <tbody>
            <% books.forEach(book=> { %>
                <tr>
                    <td>
                        <%= book.id %>
                    </td>
                    <td>
                        <%= book.title %>
                    </td>
                    <td>
                        <%= book.author %>
                    </td>
                    <td>
                        <%= book.subject %>
                    </td>
                    <td>
                        <%= (book.faculty && locals.t && locals.t(book.faculty)) ? t(book.faculty) : (book.faculty
                            || 'Noma\' lum') %>
                    </td>
                    <td>
                        <%= (book.course && locals.t && locals.t('course_' + book.course)) ? t('course_' + book.course)
                            : (book.course || 'Noma\' lum') + '-kurs' %>
                    </td>
                    <td class="actions" style="display: flex; gap: 5px;">
                        <a href="/admin/edit/<%= book.id %>" class="btn"
                            style="padding: 0.5rem 1rem; font-size: 0.9rem; background: #4a90e2; text-decoration: none; color: white;">TAHRIRLASH</a>
                        <form action="/admin/delete/<%= book.id %>" method="POST"
                            onsubmit="return confirm('Rostdan ham o\'chirmoqchimisiz?');" style="display: inline;">
                            <button type="submit" class="btn btn-danger"
                                style="padding: 0.5rem 1rem; font-size: 0.9rem;">O'CHIRISH</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
        </tbody>
    </table>

    <%- include('partials/footer') %>